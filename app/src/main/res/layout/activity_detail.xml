<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Thanh trên: nút back -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF0000">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="Quay lại" />
    </FrameLayout>

    <!-- Vùng hiển thị nhân vật ghép layer -->
    <FrameLayout
        android:id="@+id/frameCharacter"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5" />

    <!-- HÀNG 1:  colorArray -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvColors"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:paddingHorizontal="8dp"
        android:visibility="visible"
        tools:listitem="@layout/item_color" />

    <!-- HÀNG 2: Chọn nhóm bộ phận  -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNavs"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:background="#EEEEEE"
        android:paddingHorizontal="8dp"
        tools:listitem="@layout/item_tab" />

    <!-- HÀNG 3 (2-trong-1):
         - Folder Mode : danh sách folder x-y (nav.png, sắp theo zIndex/y)
         - Item Mode   : danh sách thumbnail 1..quantity (item[0] = nút Back) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOptions"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="6"
        android:background="#F0F0F0"
        android:paddingHorizontal="8dp"
        tools:listitem="@layout/item_option" />

</LinearLayout>