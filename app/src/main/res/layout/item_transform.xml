<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="#B3D6F0"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Cột trái: Reset + Rotate trái + Rotate phải -->
    <LinearLayout
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btnReset"
            android:layout_width="68dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_transform_btn"
            android:text="Reset"
            android:textColor="#E6B800"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnRotateLeft"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn"
            android:text="↺"
            android:textColor="#E6B800"
            android:textSize="26sp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnRotateRight"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn"
            android:text="↻"
            android:textColor="#E6B800"
            android:textSize="26sp" />

    </LinearLayout>

    <!-- D-Pad giữa: dùng GridLayout 3x3 -->
    <androidx.gridlayout.widget.GridLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center"
        app:columnCount="3"
        app:rowCount="3"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <!-- Hàng 0 -->
        <View
            app:layout_column="0" app:layout_row="0"
            android:layout_width="64dp" android:layout_height="64dp" />

        <Button
            android:id="@+id/btnUp"
            app:layout_column="1" app:layout_row="0"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn"
            android:text="↑"
            android:textColor="#E6B800"
            android:textSize="26sp" />

        <View
            app:layout_column="2" app:layout_row="0"
            android:layout_width="64dp" android:layout_height="64dp" />

        <!-- Hàng 1 -->
        <Button
            android:id="@+id/btnLeft"
            app:layout_column="0" app:layout_row="1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn"
            android:text="←"
            android:textColor="#E6B800"
            android:textSize="26sp" />

        <View
            app:layout_column="1" app:layout_row="1"
            android:layout_width="64dp" android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn" />

        <Button
            android:id="@+id/btnRight"
            app:layout_column="2" app:layout_row="1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn"
            android:text="→"
            android:textColor="#E6B800"
            android:textSize="26sp" />

        <!-- Hàng 2 -->
        <View
            app:layout_column="0" app:layout_row="2"
            android:layout_width="64dp" android:layout_height="64dp" />

        <Button
            android:id="@+id/btnDown"
            app:layout_column="1" app:layout_row="2"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_transform_btn"
            android:text="↓"
            android:textColor="#E6B800"
            android:textSize="26sp" />

        <View
            app:layout_column="2" app:layout_row="2"
            android:layout_width="64dp" android:layout_height="64dp" />

    </androidx.gridlayout.widget.GridLayout>

    <!-- Cột phải: Slider dọc + label Size -->
    <LinearLayout
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <SeekBar
            android:id="@+id/seekBarSize"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:max="100"
            android:progress="41"
            android:rotation="-90"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Size"
            android:textColor="#E6B800"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="48dp" />

    </LinearLayout>

</LinearLayout>
